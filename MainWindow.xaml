<Window x:Class="Noteup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:ui="http://schemas.modernwpf.com/controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Noteup"
        Height="520"
        Width="840"
        MinHeight="360"
        MinWidth="600"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        AllowsTransparency="True"
        Opacity="1">

    <Window.Resources>
        <Style x:Key="TabIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>
                            <Border x:Name="SwitchTrack" 
                                    Grid.Column="1" 
                                    Width="40" 
                                    Height="20" 
                                    CornerRadius="10" 
                                    Background="#333" 
                                    BorderBrush="#555"
                                    BorderThickness="1"
                                    Margin="10,0,0,0">
                                <Ellipse x:Name="SwitchKnob" 
                                         Width="12" 
                                         Height="12" 
                                         Fill="#888" 
                                         HorizontalAlignment="Left" 
                                         Margin="4,0,0,0"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#60CDFF"/>
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#60CDFF"/>
                                <Setter TargetName="SwitchKnob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="SwitchKnob" Property="Margin" Value="0,0,4,0"/>
                                <Setter TargetName="SwitchKnob" Property="Fill" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SidebarButtonBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarButtonFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SidebarButtonHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SidebarButtonPressBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderThickness="1"
            BorderBrush="#2c2c2c"
            CornerRadius="8"
            Background="#1c1c1c"
            SnapsToDevicePixels="True"
            Margin="0">

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="41"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Border Background="#222"
                    CornerRadius="8,8,0,0"
                    Grid.Row="0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Margin="0">
                <Grid x:Name="TitleBar"
                      Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <TextBlock Text=""
                               FontFamily="Segoe Fluent Icons"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="18"
                               Height="19"
                               Margin="0,10,0,0"/>
                    <TextBlock Text=" noteup"
                               FontFamily="Segoe UI"
                               Foreground="White"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               FontSize="18"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top"
                            Margin="0,0,0,0">

                    <Button x:Name="MinBtn"
                            Content=""
                            FontFamily="Segoe Fluent Icons"
                            Click="MinBtn_Click"
                            Width="44"
                            Height="40"
                            FontWeight="Light"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Focusable="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="Border"
                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                    To="#555555"
                                                                    Duration="0:0:0.15">
                                                        <ColorAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                        </ColorAnimation.EasingFunction>
                                                    </ColorAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="Border"
                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                    To="Transparent"
                                                                    Duration="0:0:0.15">
                                                        <ColorAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                        </ColorAnimation.EasingFunction>
                                                    </ColorAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#333333"/>
                                    </Trigger>
                                    
                                    <!-- Fix: Reset state when mouse leaves during press -->
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="False"/>
                                            <Condition Property="IsPressed" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="MaxBtn"
                            Content=""
                            FontFamily="Segoe Fluent Icons"
                            Click="MaxBtn_Click"
                            Width="44"
                            Height="40"
                            FontWeight="Light"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Focusable="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="Border"
                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                    To="#555555"
                                                                    Duration="0:0:0.15">
                                                        <ColorAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                        </ColorAnimation.EasingFunction>
                                                    </ColorAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="Border"
                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                    To="Transparent"
                                                                    Duration="0:0:0.15">
                                                        <ColorAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                        </ColorAnimation.EasingFunction>
                                                    </ColorAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#333333"/>
                                    </Trigger>
                                    
                                    <!-- Fix: Reset state when mouse leaves during press -->
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="False"/>
                                            <Condition Property="IsPressed" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="CloseBtn"
                            Content=""
                            FontFamily="Segoe Fluent Icons"
                            Click="CloseBtn_Click"
                            Width="44"
                            Height="40"
                            FontWeight="Light"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Focusable="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="0,8,0,0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="Border"
                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                    To="#e81123"
                                                                    Duration="0:0:0.15">
                                                        <ColorAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                        </ColorAnimation.EasingFunction>
                                                    </ColorAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="Border"
                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                    To="Transparent"
                                                                    Duration="0:0:0.15">
                                                        <ColorAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                        </ColorAnimation.EasingFunction>
                                                    </ColorAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#c50f1f"/>
                                    </Trigger>
                                    
                                    <!-- Fix: Reset state when mouse leaves during press -->
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="False"/>
                                            <Condition Property="IsPressed" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>
            </Border>

            <Grid Grid.Row="1" Background="Transparent" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="0"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Integrated Sidebar -->
                <Border x:Name="Sidebar"
                        Grid.Column="0"
                        Grid.Row="2"
                        Grid.RowSpan="1"
                        Background="#252525"
                        BorderBrush="#2c2c2c"
                        BorderThickness="0,0,1,0"
                        CornerRadius="0,0,0,8">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" 
                                        Direction="0" 
                                        ShadowDepth="0" 
                                        BlurRadius="15" 
                                        Opacity="0.4"/>
                    </Border.Effect>
                    <StackPanel Orientation="Vertical"
                                VerticalAlignment="Top"
                                Margin="10">
                        
                        <Button Content="&#xE74E;" 
                                FontFamily="Segoe Fluent Icons"
                                Margin="0,0,0,10"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="SidebarSave_Click"
                                ToolTip="Save"/>

                        <Button Content="&#xE74D;" 
                                FontFamily="Segoe Fluent Icons"
                                Margin="0,0,0,10"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="SidebarDelete_Click"
                                ToolTip="Delete"/>

                        <Button Content="&#xE713;" 
                                FontFamily="Segoe Fluent Icons"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="SidebarSettings_Click"
                                ToolTip="Settings"/>
                    </StackPanel>
                </Border>

                <ScrollViewer x:Name="TabScrollViewer"
                              Grid.Column="0"
                              Grid.ColumnSpan="2"
                              Grid.Row="0"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              Background="#1e1e1e"
                              Padding="4,0,4,0">
                    <StackPanel x:Name="TabBar"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="4,0,0,0">

                        <Button x:Name="AddTabButton"
        Content="&#xE710;"
        FontFamily="Segoe Fluent Icons"
        Foreground="{DynamicResource SidebarButtonFg}"
        Background="Transparent"
        BorderThickness="0"
        FontSize="14"
        Width="30"
        Height="30"
        Cursor="Hand"
        ToolTip="New tab"
        Click="AddTabButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Border"
                    Background="Transparent"
                    CornerRadius="4"
                    BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource NeutralHoverBg}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource NeutralPressedBg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- Menu Bar -->
                <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Background="#1e1e1e" BorderThickness="0,0,0,1" BorderBrush="#2c2c2c">
                    <Menu Background="Transparent" Height="25" VerticalAlignment="Center">
                        <MenuItem Header="File" Foreground="White" FontSize="13" Padding="10,0">
                            <MenuItem Header="New Tab" />
                            <MenuItem Header="Save Note" />
                            <Separator/>
                            <MenuItem Header="Exit" />
                        </MenuItem>
                    </Menu>
                </Border>

                <Grid x:Name="TabContentArea" Grid.Column="1" Grid.Row="2" Background="Transparent">
                    <TextBlock x:Name="NoTabsText"
                               Panel.ZIndex="100"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="#aaa"
                               FontSize="16"
                               FontStyle="Italic"
                               Visibility="Visible"><Run Text="no tabs open"/><LineBreak/><Run/></TextBlock>
                </Grid>

                <!-- Integrated Settings Page -->
                <Border x:Name="SettingsPage" 
                       Grid.Column="1" 
                       Grid.Row="0" 
                       Grid.RowSpan="3" 
                       Background="#1c1c1c" 
                       Visibility="Collapsed"
                       Panel.ZIndex="100"
                       CornerRadius="0,0,8,8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="20">
                        <Button Content="← Back to Notes" 
                                Click="BackToNotes_Click"
                                Background="#357EC7"
                                Foreground="White"
                                FontSize="14"
                                Padding="12,8"
                                Margin="0,0,0,20"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalAlignment="Left">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#4A90E2"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#2a6ca7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock Text="Settings" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   Margin="0,0,0,30"/>

                            <TextBlock Text="This application is currently in a highly unstable state. Do not use as your main note-taking app." 
                                   FontSize="18" 
                                   Foreground="Red"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Appearance" 
                                   FontSize="18" 
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,20,0,10"/>

                        <CheckBox x:Name="ThemeToggle"
                                  Content="Dark Mode"
                                  IsChecked="True"
                                  Checked="ThemeToggle_Checked"
                                  Unchecked="ThemeToggle_Unchecked"
                                  Style="{DynamicResource ToggleSwitchStyle}"
                                  Foreground="White"
                                  FontSize="14"/>
                        
                        <TextBlock x:Name="VersionText"
                                   Text="App version 2.0" 
                                   FontSize="14" 
                                   Foreground="#888"
                                   Cursor="Hand"
                                   MouseDown="VersionText_Click"/>
                        
                        <!-- Hidden Debug Panel -->
                        <Border x:Name="DebugPanel"
                                Background="#252525"
                                BorderBrush="#404040"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="20"
                                Margin="0,30,0,0"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="🔧 Debug Menu"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#60CDFF"
                                           Margin="0,0,0,20"/>
                                
                                <TextBlock Text="Message Box Tester"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           Margin="0,0,0,15"/>
                                
                                <!-- Title Input -->
                                <TextBlock Text="Title:" Foreground="#aaa" FontSize="13" Margin="0,0,0,4"/>
                                <TextBox x:Name="DebugTitle"
                                         Text="NoteUp"
                                         Background="#1e1e1e"
                                         Foreground="White"
                                         BorderBrush="#404040"
                                         Padding="8"
                                         Margin="0,0,0,12"/>
                                
                                <!-- Message Input -->
                                <TextBlock Text="Message:" Foreground="#aaa" FontSize="13" Margin="0,0,0,4"/>
                                <TextBox x:Name="DebugMessage"
                                         Text="This is a test message!"
                                         Background="#1e1e1e"
                                         Foreground="White"
                                         BorderBrush="#404040"
                                         Padding="8"
                                         TextWrapping="Wrap"
                                         Height="60"
                                         Margin="0,0,0,12"/>
                                
                                <!-- Icon Selection -->
                                <TextBlock Text="Icon:" Foreground="#aaa" FontSize="13" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="ℹ️ Info" Tag="Information" Click="DebugIcon_Click" Margin="0,0,8,0" Padding="12,6" Background="#1e1e1e" Foreground="White" BorderBrush="#404040" Cursor="Hand"/>
                                    <Button Content="⚠️ Warning" Tag="Warning" Click="DebugIcon_Click" Margin="0,0,8,0" Padding="12,6" Background="#1e1e1e" Foreground="White" BorderBrush="#404040" Cursor="Hand"/>
                                    <Button Content="❌ Error" Tag="Error" Click="DebugIcon_Click" Padding="12,6" Background="#1e1e1e" Foreground="White" BorderBrush="#404040" Cursor="Hand"/>
                                </StackPanel>
                                
                                <!-- Button Type Selection -->
                                <TextBlock Text="Buttons:" Foreground="#aaa" FontSize="13" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Button Content="OK" Tag="OK" Click="DebugButtons_Click" Margin="0,0,8,0" Padding="12,6" Background="#1e1e1e" Foreground="White" BorderBrush="#404040" Cursor="Hand"/>
                                    <Button Content="OK/Cancel" Tag="OKCancel" Click="DebugButtons_Click" Margin="0,0,8,0" Padding="12,6" Background="#1e1e1e" Foreground="White" BorderBrush="#404040" Cursor="Hand"/>
                                    <Button Content="Yes/No" Tag="YesNo" Click="DebugButtons_Click" Margin="0,0,8,0" Padding="12,6" Background="#1e1e1e" Foreground="White" BorderBrush="#404040" Cursor="Hand"/>
                                    <Button Content="Yes/No/Cancel" Tag="YesNoCancel" Click="DebugButtons_Click" Padding="12,6" Background="#1e1e1e" Foreground="White" BorderBrush="#404040" Cursor="Hand"/>
                                </StackPanel>
                                
                                <!-- Show Button -->
                                <Button Content="Show Message Box"
                                        Click="ShowDebugMessageBox_Click"
                                        Background="#60CDFF"
                                        Foreground="Black"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Padding="20,10"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        HorizontalAlignment="Center">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#80E0FF"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#40BDFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
